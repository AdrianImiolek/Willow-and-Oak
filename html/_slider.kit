<div class="our-works__slider slider">
    <div class="slides">
        <img src="img/slider1.webp" alt="Image#1" class="slide">
        <img src="img/slider2.webp" alt="Image#2" class="slide">
        <img src="img/slider3.webp" alt="Image#3" class="slide">
        <img src="img/slider4.webp" alt="Image#4" class="slide">
    </div>
    <button class="prev" onclick="prevSlide()">&#10094</button>
    <button class="next" onclick="nextSlide()">&#10095</button>
</div>